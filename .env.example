# ===========================================
# Gaming Arena - Environment Variables
# ===========================================
# Copy this file to .env and fill in your values

# --- Required for full functionality ---

# MongoDB connection string (required for users, scores, leaderboard, teams)
MONGODB_URI=mongodb+srv://user:password@cluster.mongodb.net/gaming-arena

# --- Optional: SideShift API (multi-coin deposits) ---
# SIDESHIFT_SECRET=your_sideshift_secret
# SIDESHIFT_AFFILIATE_ID=your_affiliate_id

# --- Optional: WalletConnect ---
# NEXT_PUBLIC_WALLETCONNECT_PROJECT_ID=your_walletconnect_project_id

# --- Contract deployment only (not needed for frontend/Vercel) ---
# PRIVATE_KEY=your_private_key
# POLYGON_AMOY_RPC=https://rpc-amoy.polygon.technology/
# POLYGON_MAINNET_RPC=https://polygon-rpc.com
